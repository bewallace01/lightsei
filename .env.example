# Copy to .env (gitignored) and fill in real values.
# `docker compose` auto-loads .env from this directory.

# Master key for AES-256-GCM encryption of workspace secrets
# (e.g. ANTHROPIC_API_KEY). 32 random bytes, base64-encoded.
# Generate with:
#   python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
LIGHTSEI_SECRETS_KEY=
